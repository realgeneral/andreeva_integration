# Базовый URL amoCRM (обычно менять не нужно)
AMO_BASE_URL=https://dermaelite.amocrm.ru

# Токен доступа amoCRM (обязателен)
AMO_ACCESS_TOKEN=PASTE_YOUR_AMO_ACCESS_TOKEN_HERE

# Базовый URL API МойСклад (по умолчанию так)
MOYSKLAD_BASE_URL=https://api.moysklad.ru/api/remap/1.2

# Токен доступа МойСклад (обязателен)
MOYSKLAD_TOKEN=PASTE_YOUR_MOYSKLAD_TOKEN_HERE

# Строка подключения к БД (PostgreSQL)
# Пример для docker-compose: postgresql://biznes:biznes@db:5432/biznesavtomatizator
DATABASE_URL=postgresql://biznes:biznes@db:5432/biznesavtomatizator

# ID кастомного поля ИНН в amoCRM (числовой ID поля)
AMO_INN_FIELD_ID=123456

# ID поля сделки «Ссылка на заказ в МойСклад» — пустое поле = сделка не обрабатывается (поллер и вебхук)
# Пустая строка = отключить проверку
AMO_MS_ORDER_LINK_FIELD_ID=3257473

# ID пользователя amo «интеграция / Бизнес Автоматизатор» (для scripts/backfill_integration_leads.py)
# Узнать: python scripts/backfill_integration_leads.py list-users
# AMO_INTEGRATION_RESPONSIBLE_USER_ID=12050794

# Telegram-логирование (опционально)
APP_NAME=amocalls-file-processor
TELEGRAM_BOT_TOKEN=PASTE_YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=PASTE_YOUR_TELEGRAM_CHAT_ID_HERE
# Отправлять ли успешные (✅) уведомления в Telegram
TELEGRAM_SEND_SUCCESS=false
# Отправлять ли уведомления об ошибках (🚨) в Telegram
TELEGRAM_SEND_ERRORS=true
# Уведомления о пропусках (нет телефона, нет контрагента в МС и т.д.)
TELEGRAM_SEND_SKIPS=true
# Прокси только для Bot API при отправке уведомлений (рантайм). На docker build / pip не влияет.
# Пример SOCKS5: socks5://user:pass@host:2080 (в образе нужен httpx[socks] из requirements.txt)
# TELEGRAM_HTTP_PROXY=

# Прокси только для docker-compose build (pip → PyPI). Не путать с TELEGRAM_HTTP_PROXY (SOCKS5 там ок).
# HTTP_PROXY=http://user:pass@proxy.example.com:8080
# HTTPS_PROXY=http://user:pass@proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1
# Если сборка зависает на "Collecting fastapi" — зеркало PyPI при docker build:
PIP_USE_MIRROR=1

# Polling: МойСклад контрагенты → amo (poll_worker.py)
POLL_INTERVAL_SECONDS=120
POLL_INITIAL_LOOKBACK_MINUTES=10

# Polling: сделки amo (контейнер amo_leads_poller). created_at = только новые; updated_at = любые правки
AMO_LEADS_POLL_DATE_FIELD=created_at
AMO_LEADS_POLL_INTERVAL_SECONDS=300
AMO_LEADS_POLL_LOOKBACK_MINUTES=10
# Вебхук add_lead в amo можно отключить; тогда оставьте false и удалите вебхук в настройках amoCRM
AMO_ADD_LEAD_WEBHOOK_ENABLED=false

# Логи (ротация раз в день, хранение 2 дня)
LOG_DIR=/app/logs
LOG_RETENTION_DAYS=2
# Доп. журнал: дата - id сделки - OK/ERROR (синхронизация ответственного по сделке). По умолчанию LOG_DIR/amo_lead_sync_results.txt; false/off — отключить
# AMO_LEAD_SYNC_RESULT_LOG=/app/logs/amo_lead_sync_results.txt

